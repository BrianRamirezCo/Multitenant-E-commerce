#  BACKEND — Environment variables (.env.example)

# --- Core ---
NODE_ENV=development                       # development | production
PORT=5000                                  # default 5000
LOG_LEVEL=debug                            # debug (dev) / info (prod)

# --- Database (MongoDB Atlas) ---
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/dbname   # [REQUIRED]
TEST_MONGO_URI=                            # [OPTIONAL] para tests

# --- JWT auth secrets (generá con: openssl rand -base64 48) ---
ACCESS_TOKEN_SECRET=change-me-strong-random-string       # [REQUIRED en prod]
REFRESH_TOKEN_SECRET=change-me-different-random-string    # [REQUIRED en prod]
ACCESS_TOKEN_EXPIRES=15m                   # [OPTIONAL] default 15m
REFRESH_TOKEN_EXPIRES=7d                   # [OPTIONAL] default 7d

# --- URLs / dominios ---
ROOT_DOMAIN=yourapp.com                    # [REQUIRED en prod]
PLATFORM_URL=http://localhost:5173         # [REQUIRED en prod]
PLATFORM_PUBLIC_URL=                       # [OPTIONAL] override para MP back_url (ngrok en dev)
API_URL=http://localhost:5000              # [REQUIRED en prod]
CORS_EXTRA_ORIGINS=                        # [OPTIONAL] ej: https://app.vercel.app,https://tienda.com

# --- MercadoPago ---
MP_PLATFORM_TOKEN=                         # [REQUIRED en prod] token de plataforma
MP_TEST_ACCESS_TOKEN=                      # [OPTIONAL] sandbox
# Nota: cada tienda guarda su PROPIO token en la DB (Tenant.mercadoPago.accessToken)

# --- Cloudinary (subida de imágenes) ---
CLOUDINARY_CLOUD_NAME=                     # [REQUIRED]
CLOUDINARY_API_KEY=                        # [REQUIRED]
CLOUDINARY_API_SECRET=                     # [REQUIRED]

# --- Email (Resend) ---
RESEND_API_KEY=                            # [REQUIRED para emails]
EMAIL_FROM=onboarding@resend.dev           # [OPTIONAL] usá un dominio verificado en prod
STORE_OWNER_EMAIL=                         # [OPTIONAL] notificaciones al dueño

# --- Job de carrito abandonado ---
ABANDONED_CART_MINUTES=60                  # [OPTIONAL] default 2 (¡poné 60 en prod!)
ABANDONED_CART_CRON=* * * * *              # [OPTIONAL] default cada minuto