# =============================================================================
#  FRONTEND — Environment variables (.env.example)

# URL base del backend API. Incluí el sufijo /api.
# Dev:  http://localhost:5000/api
# Prod: https://api.yourapp.com/api
VITE_API_URL=http://localhost:5000/api          # [REQUIRED]

# Dominio raíz para resolver el tenant desde el subdominio en producción.
VITE_ROOT_DOMAIN=yourapp.com                     # [REQUIRED en prod]
